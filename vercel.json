{
  "buildCommand": "npm run build",
  "nodeVersion": "20.x",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/connections/:id", "destination": "/api/connections" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
